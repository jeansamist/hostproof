# =============================================================================
# Hostproof API — Production Environment
# Copy this file to .env.api and fill in the values.
# The deploy script will copy .env.api → apps/api/.env (and apps/api/build/.env)
# =============================================================================

# Node
TZ=UTC
PORT=1234
HOST=0.0.0.0
NODE_ENV=production

# App
LOG_LEVEL=info
APP_KEY=                                   # node ace generate:key
APP_URL=https://api.yourdomain.com

# Session
SESSION_DRIVER=cookie

# Database (PostgreSQL)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=hostproof
DB_PASSWORD=
DB_DATABASE=hostproof

# Mail
MAIL_MAILER=smtp
MAIL_FROM_NAME=Hostproof
MAIL_FROM_ADDRESS=no-reply@yourdomain.com
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USERNAME=
SMTP_PASSWORD=

# Frontend (used in emails / CORS)
FRONTEND_APP_URL=https://app.yourdomain.com

# Google GenAI
GOOGLE_API_KEY=
