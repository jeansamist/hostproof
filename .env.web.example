# =============================================================================
# Hostproof Web — Production Environment
# Copy this file to .env.web and fill in the values.
# The deploy script will copy .env.web → apps/web/.env.production.local
# NEXT_PUBLIC_* vars are baked in at build time — set them before building.
# =============================================================================

# Public (baked into the client bundle at build time)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_APP_URL=https://app.yourdomain.com
