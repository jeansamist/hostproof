{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@packages/functions": ["../functions/src/index.ts"],
      "@packages/hooks": ["../hooks/src/index.ts"],
      "@packages/hooks/use-mobile": ["../hooks/src/use-mobile.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
